{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist-ui/renderer",
    "types": ["node", "react", "react-dom", "vite/client"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["src-ui/renderer/*"]
    }
  },
  "include": [
    "src-ui/**/*.ts",
    "src-ui/**/*.tsx",
    "src-core/**/*.ts",
    "platform_tools/**/*.ts",
    "platform_tools/**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "dist-ui",
    "release",
    "build",
    ".GPTBridge_RuntimeSandbox",
    "backups"
  ]
}
